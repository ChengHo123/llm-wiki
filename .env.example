# ============================================================
# 部署必填（多數欄位通用，依需求改密碼／key）
# ============================================================

# ── Postgres（wiki + litellm 共用此 instance，自動建兩個 DB） ──
POSTGRES_USER=wiki
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wiki

# ── LiteLLM proxy ──
LITELLM_MASTER_KEY=sk-change-me
# LiteLLM UI 帳密：建議與 ADMIN_USERNAME / ADMIN_PASSWORD 設相同，這樣兩邊共用一組帳密
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=change-me
# 與上方 POSTGRES_USER/PASSWORD 對應，host 固定為 postgres（compose service name）
LITELLM_DATABASE_URL=postgresql://wiki:change-me@postgres:5432/litellm

# ── Backend → LiteLLM virtual key ──
# 首次啟動後：
#   本機：http://localhost:4000（UI 帳密用上面的 LITELLM_UI_*）
#   雲端：https://<DOMAIN>/litellm/ui（用後台帳密登入）
# 建立 virtual key 後填回此欄
LLM_API_KEY=sk-replace-with-virtual-key
LLM_MODEL=qwen/qwen3.5-122b-a10b
VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# ── Admin 後台帳密 ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── pgAdmin ──
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ============================================================
# 本機開發用（local docker-compose.yml）
# ============================================================

# ── ngrok（local LINE webhook 測試）──
# 從 https://dashboard.ngrok.com/get-started/your-authtoken 取得
# 若有 reserved static domain，docker-compose.yml 已綁定，URL 永久不變
NGROK_AUTHTOKEN=

# ============================================================
# 共用：LINE Bot（本機 ngrok / 雲端 Caddy 都要）
# ============================================================

# LINE Developers Console → Messaging API channel
# Channel secret: Basic settings → Channel secret
# Channel access token: Messaging API → Channel access token (long-lived)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Bot 推送給用戶的前端網址（一鍵登入連結會以此為前綴）
# 本機開發：http://localhost:3000 或 ngrok 域名
# 生產：https://${DOMAIN}
FRONTEND_URL=http://localhost:3000

# ============================================================
# 雲端部署用（docker-compose.prod.yml，本檔放在 Oracle VM /opt/llm-wiki/.env，不進 git）
# ============================================================

# ── GHCR image 來源 ──
# 你的 GitHub username（全小寫），workflow 會 push 到 ghcr.io/<owner>/llm-wiki-{backend,frontend}
GHCR_OWNER=your-github-username

# 部署的 image tag。由 deploy.sh 自動寫入；手動指定可改。
IMAGE_TAG=latest

# 只有 GHCR package 設為 private 才需要（公開 package 留空即可）
# Personal Access Token，scope: read:packages
# 建立位置：https://github.com/settings/tokens（classic 或 fine-grained 都可）
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── DuckDNS（免費 DDNS） ──
# 1. 用 GitHub 登入 https://www.duckdns.org
# 2. 新增 subdomain，記下 token
# 容器會每 5 分鐘把 Oracle VM 的 public IP 同步到 DuckDNS
DUCKDNS_SUBDOMAIN=your-subdomain
DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Caddy（HTTPS 自動取證） ──
# DOMAIN 必須與 DUCKDNS_SUBDOMAIN 對應
DOMAIN=your-subdomain.duckdns.org
# Let's Encrypt 通知信箱（證書即將過期時會寄通知）
LE_EMAIL=you@example.com

# 時區（影響 cron 備份時間、log 時戳）
TZ=Asia/Taipei

# ============================================================
# 進階（一般不用改）
# ============================================================

# 檢索容量上限；達到即拒絕上傳，避免 query 漏頁
# MAX_WIKI_PAGES=100

# LINE bot 防腳本：per-user 限速（in-memory，重啟後重置）
# 同一 LINE 使用者兩則訊息間最短間隔（秒）
# LINE_USER_COOLDOWN_SECONDS=5
# 同一 LINE 使用者每分鐘最多訊息數
# LINE_USER_RPM_LIMIT=5

# ===== 本機開發 (backend 直跑時) =====
# LLM_BASE_URL=http://localhost:4000/v1
# DATABASE_URL=postgresql+asyncpg://wiki:wiki@localhost:5432/wiki
# UPLOAD_DIR=./uploads
# MAX_UPLOAD_SIZE_MB=50
