# ===== 部署必填 =====
# Postgres（wiki + litellm 共用此 instance，自動建兩個 DB）
POSTGRES_USER=wiki
POSTGRES_PASSWORD=wiki
POSTGRES_DB=wiki

# LiteLLM
LITELLM_MASTER_KEY=sk-change-me
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=change-me
LITELLM_DATABASE_URL=postgresql://wiki:wiki@postgres:5432/litellm

# Backend → LiteLLM virtual key（首次啟動後進 LiteLLM UI 建立）
LLM_API_KEY=sk-replace-with-virtual-key
LLM_MODEL=nemotron

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ===== 本機開發 (backend 直跑時) =====
# LLM_BASE_URL=http://localhost:4000/v1
# DATABASE_URL=postgresql+asyncpg://wiki:wiki@localhost:5432/wiki
# UPLOAD_DIR=./uploads
# MAX_UPLOAD_SIZE_MB=50
