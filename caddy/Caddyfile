{
	email {$LE_EMAIL}
}

{$DOMAIN} {
	encode gzip

	# LiteLLM admin UI / API — 使用與後台相同的帳密（ADMIN_USERNAME / ADMIN_PASSWORD）登入
	handle /litellm/* {
		reverse_proxy litellm:4000
	}

	# Frontend nginx already proxies /api/* to backend:8000, so we just front everything to it.
	handle {
		reverse_proxy frontend:80 {
			# Cover the LLM ingest path which can take 30s+
			transport http {
				read_timeout 600s
				write_timeout 600s
			}
		}
	}
}
