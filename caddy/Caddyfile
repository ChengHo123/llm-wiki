{
	email {$LE_EMAIL}
}

# LiteLLM admin UI — http://<DOMAIN>:4000/ui
# 純 HTTP：LiteLLM 內部產生的 redirect 用 http scheme，套 TLS 會在 login redirect 時破。
http://{$DOMAIN}:4000 {
	reverse_proxy litellm:4000
}

{$DOMAIN} {
	encode gzip

	# Frontend nginx already proxies /api/* to backend:8000, so we just front everything to it.
	handle {
		reverse_proxy frontend:80 {
			# Cover the LLM ingest path which can take 30s+
			transport http {
				read_timeout 600s
				write_timeout 600s
			}
		}
	}
}
